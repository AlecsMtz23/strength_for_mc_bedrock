<body>
    <div class="container">
        <h1>⚔️ Fuerza en Minecraft Bedrock ⚔️</h1>
        <div class="input-group">
            <div class="input-field">
                <label for="baseDamage">Daño base (sin fuerza):</label>
                <input type="number" id="baseDamage" step="any" min="0" value="1" placeholder="Ej: 5">
            </div>
            <div class="input-field">
                <label for="strengthLevel">Nivel de fuerza (0+):</label>
                <input type="number" id="strengthLevel" min="0" value="5" placeholder="Ej: 5">
            </div>
        </div>
        <button id="calcular">Calcular daño</button>

        <div class="resultados" id="resultados">
            <!-- Aquí se mostrarán los resultados -->
        </div>
        <footer>
            Fórmula: Daño base × 1.3<sup>nivel</sup> + (1.3<sup>nivel</sup> - 1) / 0.3<br>
            Crítico: +50% al total
        </footer>
    </div>

    <script>
        document.getElementById('calcular').addEventListener('click', function() {
            const baseInput = document.getElementById('baseDamage');
            const levelInput = document.getElementById('strengthLevel');
            const resultadosDiv = document.getElementById('resultados');

            // Obtener valores y validar
            let base = parseFloat(baseInput.value);
            let level = parseInt(levelInput.value, 10);

            if (isNaN(base) || base < 0) {
                base = 0;
                baseInput.value = 0;
            }
            if (isNaN(level) || level < 0) {
                level = 0;
                levelInput.value = 0;
            }

            // Determinar niveles a mostrar (actual y hasta 4 anteriores)
            const minLevel = Math.max(0, level - 4);
            const maxLevel = level;

            // Crear tabla de resultados
            let html = '';
            if (level === 0 && minLevel === 0) {
                html = '<table><tr><th>Nivel</th><th>Daño normal</th><th class="critical">Daño crítico</th></tr>';
            } else {
                html = '<table><tr><th>Nivel</th><th>Daño normal</th><th class="critical">Daño crítico</th></tr>';
            }

            for (let lvl = maxLevel; lvl >= minLevel; lvl--) {
                // Calcular según fórmula: base * 1.3^lvl + (1.3^lvl - 1) / 0.3
                const pow = Math.pow(1.3, lvl);
                const normal = base * pow + (pow - 1) / 0.3;
                const critico = normal * 1.5;

                // Formatear a 2 decimales
                const normalStr = normal.toFixed(2);
                const criticoStr = critico.toFixed(2);

                html += `<tr>
                    <td class="nivel">${lvl}</td>
                    <td>${normalStr}</td>
                    <td class="critical">${criticoStr}</td>
                </tr>`;
            }
            html += '</table>';

            // Si no hay resultados (raro, pero por si acaso)
            if (maxLevel < minLevel) {
                html = '<p class="error">No hay niveles para mostrar.</p>';
            }

            resultadosDiv.innerHTML = html;
        });

        // Ejecutar cálculo inicial al cargar la página
        window.addEventListener('load', function() {
            document.getElementById('calcular').click();
        });
    </script>
</body>
